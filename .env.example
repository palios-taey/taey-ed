# Taey-Ed central server — environment configuration (example).
# Copy to .env (gitignored) and adjust. All have sane defaults; the server runs
# without any of these set, using the defaults shown.

# Persistent server-state root (signatures, variant BTs, hash index, screen
# sessions, escalation state, measure-grid corpus, ...).
TAEY_ED_DATA_DIR=/home/user/taey-ed-data

# Path to the API secrets JSON (Gemini/Anthropic keys, JWT secret,
# internal_api_key, Stripe). NEVER commit this file. See secrets_loader.py for
# the required shape.
TAEY_ED_SECRETS_PATH=/etc/taey-ed/secrets.json

# Strict secret validation at startup (1 = production). Unset/0 = dev mode
# (tolerates missing secrets with ephemeral defaults).
TAEY_ED_PRODUCTION=1

# Server bind host/port (used in prompts that tell consulting Claude where to
# POST back, and for the worker).
TAEY_ED_HOST=127.0.0.1
TAEY_ED_PORT=5003

# Public-facing app URL used in verification / receipt email links.
TAEY_ED_APP_URL=https://app.taey.ai
